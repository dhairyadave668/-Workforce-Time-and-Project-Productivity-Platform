# ── Source Control ─────────────────────────────────────────────
**/.git
**/.gitignore

# ── Dependencies (reinstalled inside container via npm ci) ─────
node_modules/

# ── Build Output (rebuilt inside container) ────────────────────
dist/
dist-ssr/
build/

# ── Secrets & Environment ──────────────────────────────────────
# VITE_API_URL is passed as a build ARG, not via .env files
.env
.env.local
.env.development
.env.production
.env.*.local

# ── Test & Coverage ────────────────────────────────────────────
coverage/

# ── Logs ───────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── IDE & Editor ───────────────────────────────────────────────
**/.vscode
**/.idea
**/.history

# ── Docker Files (not needed inside the image) ─────────────────
Dockerfile
.dockerignore
docker-compose.yml
docker-compose*.yml

# ── OS Junk ────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
[Dd]esktop.ini

# ── TypeScript Build Cache ─────────────────────────────────────
*.tsbuildinfo

# ── Source Maps (not needed in image, Nginx serves built files) ─
**/*.map

# ── Docs ───────────────────────────────────────────────────────
README.md
**/*.md