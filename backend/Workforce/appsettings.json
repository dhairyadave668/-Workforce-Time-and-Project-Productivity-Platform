{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_CONNECTION_STRING"
  },
  "Jwt": {
    "Key": "YOUR_SECRET_KEY",
    "Issuer": "WorkforceApp",
    "Audience": "WorkforceAppUsers",
    "ExpiryMinutes": 60
  },
  "AllowedHosts": "*"
}